# Akasha ontology — namespace: word
# atoms: 1413

def "word:akk:bull_of_heaven" "GU4.AN.NA, 'the Bull of Heaven' — the Sumero-Babylonian figure that became Taurus; the very bull Ishtar sent against Gilgamesh. The Greeks later made it the bull of Europa."
ln word:akk:bull_of_heaven astro:constellation:taurus sys:refers_to
ln word:akk:bull_of_heaven myth:greek_europa_bull @related_to
ln word:akk:bull_of_heaven myth:babylonian_sky_origin sys:part_of
set.add name="ontology.star_names" id="word:akk:bull_of_heaven"

def "word:akk:goat_fish" "SUHUR.MAŠ, 'the Goat-Fish' — one of the oldest constellations, the goat-fish of the wise god Ea, which became Capricornus. The Greeks redrew it as the god Pan fleeing into the river."
ln word:akk:goat_fish astro:constellation:capricornus sys:refers_to
ln word:akk:goat_fish myth:greek_pan_seagoat @parallels
set.add name="ontology.star_names" id="word:akk:goat_fish"

def "word:akk:great_twins" "MAŠ.TAB.BA.GAL.GAL, 'the Great Twins' — the Babylonian twin gods Lugalgirra and Meslamtaea, the figure the Greeks made the brothers Castor and Pollux: Gemini."
ln word:akk:great_twins astro:constellation:gemini sys:refers_to
ln word:akk:great_twins myth:greek_dioscuri @related_to
ln word:akk:great_twins myth:babylonian_sky_origin sys:part_of
set.add name="ontology.star_names" id="word:akk:great_twins"

def "word:akk:hired_man" "LÚ.ḪUN.GÁ, 'the Hired Man' — the Babylonian farm-labourer who occupied the stars later redrawn as the Ram, Aries. The figure changed; the place in the circle did not."
ln word:akk:hired_man astro:constellation:aries sys:refers_to
ln word:akk:hired_man myth:greek_golden_ram @related_to
set.add name="ontology.star_names" id="word:akk:hired_man"

def "word:akk:nunki" "NUN.KI — a sacred Sumerian place-name (the holy city of Eridu) carried up into the sky, now borne by a star of Sagittarius; the one star-name of Sumerian origin still in everyday use, the deepest-rooted name in the catalogue."
ln word:akk:nunki astro:star:nunki sys:refers_to
ln word:akk:nunki astro:constellation:sagittarius @names_part_of
ln word:akk:nunki myth:babylonian_sky_origin @related_to
set.add name="ontology.star_names" id="word:akk:nunki"

def "word:akk:sebettu" "Sebettu, 'the Seven' — the seven gods, the Babylonian name for the Pleiades; one more of the world's many seven-fold readings of that little cluster."
ln word:akk:sebettu astro:constellation:taurus sys:refers_to
ln word:akk:sebettu pleiades sys:refers_to
ln word:akk:sebettu myth:greek_pleiades @related_to
ln word:akk:sebettu word:sa:krittika @related_to
set.add name="ontology.star_names" id="word:akk:sebettu"

def "word:akk:the_arrow" "KAK.SI.SÁ, 'the Arrow' — the Babylonian name for the brightest star, Sirius, which the Chinese called the Celestial Wolf and the Egyptians Sopdet of the flood."
ln word:akk:the_arrow astro:star:sirius sys:refers_to
ln word:akk:the_arrow word:la:sirius @related_to
ln word:akk:the_arrow word:zh:天狼 @related_to
set.add name="ontology.star_names" id="word:akk:the_arrow"

def "word:akk:the_furrow" "AB.SÍN, 'the Furrow' — the Babylonian field-goddess holding an ear of grain, who became the Maiden Virgo; the grain-ear is the star Spica."
ln word:akk:the_furrow astro:constellation:virgo sys:refers_to
ln word:akk:the_furrow myth:greek_astraea @related_to
ln word:akk:the_furrow word:la:spica @related_to
set.add name="ontology.star_names" id="word:akk:the_furrow"

def "word:akk:the_great_one" "GU.LA, 'the Great One' — the Babylonian water-pouring god Ea, the figure the Greeks made the cup-bearer Ganymede: Aquarius, source of the heavenly streams."
ln word:akk:the_great_one astro:constellation:aquarius sys:refers_to
ln word:akk:the_great_one myth:greek_ganymede @related_to
set.add name="ontology.star_names" id="word:akk:the_great_one"

def "word:akk:the_lion_bab" "UR.GU.LA, 'the Lion' — the Babylonian lion that became Leo; the royal star Regulus at its breast was the king-star in Mesopotamia long before Rome."
ln word:akk:the_lion_bab astro:constellation:leo sys:refers_to
ln word:akk:the_lion_bab myth:greek_nemean_lion @related_to
set.add name="ontology.star_names" id="word:akk:the_lion_bab"

def "word:akk:the_scorpion_bab" "GIR.TAB, 'the Scorpion' — the Babylonian scorpion that became Scorpius; the half-scorpion guardians of the Epic of Gilgamesh stand at the mountain where the sun rises."
ln word:akk:the_scorpion_bab astro:constellation:scorpius sys:refers_to
ln word:akk:the_scorpion_bab myth:greek_celestial_scorpion @related_to
set.add name="ontology.star_names" id="word:akk:the_scorpion_bab"

def "word:akk:true_shepherd" "SIPA.ZI.AN.NA, 'the True Shepherd of Anu' — the Babylonian figure on the stars the Greeks made the hunter Orion and the Maya a turtle; the Egyptians saw there Sah, the soul of Osiris."
ln word:akk:true_shepherd astro:constellation:orion sys:refers_to
ln word:akk:true_shepherd myth:greek_orion @related_to
set.add name="ontology.star_names" id="word:akk:true_shepherd"

def "word:akk:zibanitu" "Zibānītu, 'the Balance' — the Babylonian scales that became Libra; the word also named the Scorpion's claws, which is why the Arabs called Libra's stars az-zubānā, the claws, and the Greeks long reckoned the Scales part of the Scorpion."
ln word:akk:zibanitu astro:constellation:libra sys:refers_to
ln word:akk:zibanitu myth:greek_libra_scales @related_to
ln word:akk:zibanitu word:ar:الزبانى_الجنوبي @related_to
set.add name="ontology.star_names" id="word:akk:zibanitu"

def "word:ar:آخر_النهر" "Ākhir an-Nahr, 'the end of the river' — the star marking the far end of the celestial river Eridanus; the source of the star-name Achernar."
ln word:ar:آخر_النهر astro:star:achernar sys:refers_to
ln word:ar:آخر_النهر astro:constellation:eridanus @names_part_of
set.add name="ontology.star_names" id="word:ar:آخر_النهر"

def "word:ar:الأنف" "al-Anf, 'the nose' — the star at the muzzle of Pegasus; the source of the star-name Enif."
ln word:ar:الأنف astro:star:enif sys:refers_to
ln word:ar:الأنف astro:constellation:pegasus @names_part_of
set.add name="ontology.star_names" id="word:ar:الأنف"

def "word:ar:البقار" "al-Baqqār, 'the herdsman' (ox-driver) — a star of Bootes, the figure who drives the oxen of the Wain around the pole; the source of the star-name Nekkar. The Herdsman's own name, beside Arcturus 'the bear-guard'."
ln word:ar:البقار astro:star:nekkar sys:refers_to
ln word:ar:البقار astro:constellation:bootes @names_part_of
ln word:ar:البقار word:la:arcturus @related_to
set.add name="ontology.star_names" id="word:ar:البقار"

def "word:ar:الثريا" "ath-Thurayyā, 'the abundant little ones' — the Arabic name and lunar mansion that is the Pleiades; the source of the given name Thuraya / Soraya."
ln word:ar:الثريا astro:constellation:taurus sys:refers_to
ln word:ar:الثريا pleiades sys:refers_to
ln word:ar:الثريا word:ar:منازل_القمر sys:part_of
ln word:ar:الثريا word:uk:volosozhary @related_to
set.add name="ontology.star_names" id="word:ar:الثريا"

def "word:ar:الثعبان" "ath-Thuʿbān, 'the serpent' — a star in the coils of Draco; the source of the star-name Thuban. Through the slow precession of the equinoxes it was the pole star around 3000 BCE, when the Egyptian pyramids were aligned to it."
ln word:ar:الثعبان astro:star:thuban sys:refers_to
ln word:ar:الثعبان astro:constellation:draco @names_part_of
ln word:ar:الثعبان myth:greek_draco_ladon @related_to
ln word:ar:الثعبان word:la:polaris @related_to
set.add name="ontology.star_names" id="word:ar:الثعبان"

def "word:ar:الجبهة" "al-Jabhah, 'the forehead' (the lion's mane) — a star in the mane of Leo; the source of the star-name Algieba. With Regulus (the heart) and Denebola (the tail), the Lion too is spelled out in his own stars."
ln word:ar:الجبهة astro:star:algieba sys:refers_to
ln word:ar:الجبهة astro:constellation:leo @names_part_of
ln word:ar:الجبهة myth:greek_nemean_lion @related_to
set.add name="ontology.star_names" id="word:ar:الجبهة"

def "word:ar:الجبهة_العقرب" "al-Jabhah, 'the forehead' (of the Scorpion) — the bright star at the scorpion's brow; the source of the star-name Dschubba. The same word, jabhah, named the Lion's forehead, Algieba — one body-word, two beasts."
ln word:ar:الجبهة_العقرب astro:star:dschubba sys:refers_to
ln word:ar:الجبهة_العقرب astro:constellation:scorpius @names_part_of
ln word:ar:الجبهة_العقرب word:ar:الجبهة @related_to
set.add name="ontology.star_names" id="word:ar:الجبهة_العقرب"

def "word:ar:الجدي" "al-Jadī, 'the kid' (young goat) — the lead star at the head of the sea-goat Capricornus; the source of the star-name Algedi."
ln word:ar:الجدي astro:star:algedi sys:refers_to
ln word:ar:الجدي astro:constellation:capricornus @names_part_of
ln word:ar:الجدي myth:greek_pan_seagoat @related_to
set.add name="ontology.star_names" id="word:ar:الجدي"

def "word:ar:الجناح" "al-Janāḥ, 'the wing' — the star at the wing of the Crow, Corvus; the source of the star-name Gienah."
ln word:ar:الجناح astro:star:gienah sys:refers_to
ln word:ar:الجناح astro:constellation:corvus @names_part_of
set.add name="ontology.star_names" id="word:ar:الجناح"

def "word:ar:الجنب" "al-Janb, 'the flank' — a corner-star of the Great Square at the horse's side; the source of the star-name Algenib."
ln word:ar:الجنب astro:star:algenib sys:refers_to
ln word:ar:الجنب astro:constellation:pegasus @names_part_of
set.add name="ontology.star_names" id="word:ar:الجنب"

def "word:ar:الحمل" "al-Ḥamal, 'the ram' — the brightest star of Aries, marking the ram's head; the source of the star-name Hamal."
ln word:ar:الحمل astro:star:hamal sys:refers_to
ln word:ar:الحمل astro:constellation:aries @names_part_of
ln word:ar:الحمل myth:greek_golden_ram @related_to
set.add name="ontology.star_names" id="word:ar:الحمل"

def "word:ar:الدب" "ad-Dubb, 'the bear' (from ẓahr ad-dubb, the bear's back) — the star at the bowl of the Dipper, and with Merak one of the two Pointers that aim at the pole star; the source of the star-name Dubhe."
ln word:ar:الدب astro:star:dubhe sys:refers_to
ln word:ar:الدب astro:constellation:ursa_major @names_part_of
ln word:ar:الدب myth:greek_callisto_bear @related_to
ln word:ar:الدب word:la:polaris @related_to
set.add name="ontology.star_names" id="word:ar:الدب"

def "word:ar:الزبانى_الجنوبي" "az-Zubānā al-Janūbī, 'the southern claw' — a chief star of Libra, named as a claw of the Scorpion, from the age when the Scales were reckoned part of Scorpius; the source of the star-name Zubenelgenubi."
ln word:ar:الزبانى_الجنوبي astro:star:zubenelgenubi sys:refers_to
ln word:ar:الزبانى_الجنوبي astro:constellation:libra @names_part_of
ln word:ar:الزبانى_الجنوبي myth:greek_libra_scales @related_to
ln word:ar:الزبانى_الجنوبي myth:greek_celestial_scorpion @related_to
set.add name="ontology.star_names" id="word:ar:الزبانى_الجنوبي"

def "word:ar:الزبانى_الشمالي" "az-Zubānā ash-Shamālī, 'the northern claw' — the companion claw-star of Libra; the source of the star-name Zubeneschamali. With its southern twin it preserves, in name, the Scorpion's lost claws."
ln word:ar:الزبانى_الشمالي astro:star:zubeneschamali sys:refers_to
ln word:ar:الزبانى_الشمالي astro:constellation:libra @names_part_of
ln word:ar:الزبانى_الشمالي myth:greek_celestial_scorpion @related_to
set.add name="ontology.star_names" id="word:ar:الزبانى_الشمالي"

def "word:ar:الساق_بيغاسوس" "as-Sāq, 'the shin' — a star of the winged horse's leg in the Great Square; the source of the star-name Scheat."
ln word:ar:الساق_بيغاسوس astro:star:scheat sys:refers_to
ln word:ar:الساق_بيغاسوس astro:constellation:pegasus @names_part_of
set.add name="ontology.star_names" id="word:ar:الساق_بيغاسوس"

def "word:ar:السلحفاة" "as-Sulaḥfāt, 'the tortoise' — an Arabic name for a star of the Lyre, recalling that the first lyre was strung across a tortoise shell; the source of the star-name Sulafat. The instrument of Orpheus, remembered in the sky as the shell it was made from."
ln word:ar:السلحفاة astro:star:sulafat sys:refers_to
ln word:ar:السلحفاة astro:constellation:lyra @names_part_of
ln word:ar:السلحفاة myth:greek_orpheus_lyre @related_to
set.add name="ontology.star_names" id="word:ar:السلحفاة"

def "word:ar:السها" "as-Suhā, 'the overlooked one' — the faint star beside Mizar, by which keen eyesight was tested; the source of the star-name Alcor."
ln word:ar:السها astro:star:alcor sys:refers_to
ln word:ar:السها astro:constellation:ursa_major @names_part_of
set.add name="ontology.star_names" id="word:ar:السها"

def "word:ar:الشرطان" "ash-Sharaṭān, 'the two signs' — the pair of stars at the Ram's head, the first of the Arabic lunar mansions; the source of the star-name Sheratan."
ln word:ar:الشرطان astro:star:sheratan sys:refers_to
ln word:ar:الشرطان astro:constellation:aries @names_part_of
ln word:ar:الشرطان word:ar:منازل_القمر sys:part_of
set.add name="ontology.star_names" id="word:ar:الشرطان"

def "word:ar:الشلياق" "ash-Shilyāq, 'the harp' (or the tortoise) — the Arabic name for the Lyre itself, source of the star-name Sheliak; with Sulafat it keeps both the instrument and the shell it was made from alive in the stars."
ln word:ar:الشلياق astro:star:sheliak sys:refers_to
ln word:ar:الشلياق astro:constellation:lyra @names_part_of
set.add name="ontology.star_names" id="word:ar:الشلياق"

def "word:ar:الشولة" "ash-Shaula, 'the raised sting' — the star at the upcurved tip of the Scorpion's tail; the source of the star-name Shaula. With Antares (the heart), the Scorpion's body is named end to end."
ln word:ar:الشولة astro:star:shaula sys:refers_to
ln word:ar:الشولة astro:constellation:scorpius @names_part_of
ln word:ar:الشولة myth:greek_celestial_scorpion @related_to
set.add name="ontology.star_names" id="word:ar:الشولة"

def "word:ar:الصدر_الدجاجة" "aṣ-Ṣadr, 'the breast' (of the Hen/Swan) — the star at the heart of Cygnus; the source of the star-name Sadr."
ln word:ar:الصدر_الدجاجة astro:star:sadr sys:refers_to
ln word:ar:الصدر_الدجاجة astro:constellation:cygnus @names_part_of
set.add name="ontology.star_names" id="word:ar:الصدر_الدجاجة"

def "word:ar:الصدر_كاسيوبيا" "aṣ-Ṣadr, 'the breast' (of the seated Queen) — a chief star of Cassiopeia; the source of the star-name Schedar. The same Arabic word, ṣadr, names the breast of two different sky-figures."
ln word:ar:الصدر_كاسيوبيا astro:star:schedar sys:refers_to
ln word:ar:الصدر_كاسيوبيا astro:constellation:cassiopeia @names_part_of
ln word:ar:الصدر_كاسيوبيا word:ar:الصدر_الدجاجة @related_to
set.add name="ontology.star_names" id="word:ar:الصدر_كاسيوبيا"

def "word:ar:العذارى" "al-ʿAdhārā, 'the maidens' — a star of Canis Major; the source of the star-name Adhara. With Mirzam, Wezen, and Aludra around Sirius, the Dog is named limb and flank."
ln word:ar:العذارى astro:star:adhara sys:refers_to
ln word:ar:العذارى astro:constellation:canis_major @names_part_of
set.add name="ontology.star_names" id="word:ar:العذارى"

def "word:ar:العذرة" "al-ʿUdhra — a star in the hind of the Great Dog; the source of the star-name Aludra."
ln word:ar:العذرة astro:star:aludra sys:refers_to
ln word:ar:العذرة astro:constellation:canis_major @names_part_of
set.add name="ontology.star_names" id="word:ar:العذرة"

def "word:ar:الفخذ" "al-Fakhdh, 'the thigh' (of the Bear) — a star of the Dipper's bowl; the source of the star-name Phecda."
ln word:ar:الفخذ astro:star:phecda sys:refers_to
ln word:ar:الفخذ astro:constellation:ursa_major @names_part_of
set.add name="ontology.star_names" id="word:ar:الفخذ"

def "word:ar:الفرد" "al-Fard, 'the solitary one' — the lone bright star in the long dim sprawl of Hydra; the source of the star-name Alphard."
ln word:ar:الفرد astro:star:alphard sys:refers_to
ln word:ar:الفرد astro:constellation:hydra @names_part_of
set.add name="ontology.star_names" id="word:ar:الفرد"

def "word:ar:القائد" "al-Qāʾid, 'the leader' — the star at the end of the Dipper's handle, leader of the banāt naʿsh, the 'daughters of the bier': for the old Arabs these seven stars were not a Bear at all, but a coffin followed by mourning women. The source of the star-name Alkaid."
ln word:ar:القائد astro:star:alkaid sys:refers_to
ln word:ar:القائد astro:constellation:ursa_major @names_part_of
ln word:ar:القائد grief @illustrates
set.add name="ontology.star_names" id="word:ar:القائد"

def "word:ar:اللسعة" "al-Lasʿa, 'the sting' — the star paired with Shaula at the very tip of the Scorpion's curled tail; the source of the star-name Lesath."
ln word:ar:اللسعة astro:star:lesath sys:refers_to
ln word:ar:اللسعة astro:constellation:scorpius @names_part_of
ln word:ar:اللسعة word:ar:الشولة @related_to
set.add name="ontology.star_names" id="word:ar:اللسعة"

def "word:ar:المراق" "al-Maraqq, 'the loins' — a star marking the side of the chained princess Andromeda; the source of the star-name Mirach."
ln word:ar:المراق astro:star:mirach sys:refers_to
ln word:ar:المراق astro:constellation:andromeda @names_part_of
ln word:ar:المراق myth:greek_perseus_andromeda @related_to
set.add name="ontology.star_names" id="word:ar:المراق"

def "word:ar:المراق_الدب" "al-Maraqq, 'the loins' (of the Bear) — the second Pointer star of the Dipper; the source of the star-name Merak. The same word names Mirach, the loins of Andromeda."
ln word:ar:المراق_الدب astro:star:merak sys:refers_to
ln word:ar:المراق_الدب astro:constellation:ursa_major @names_part_of
ln word:ar:المراق_الدب word:ar:المراق @related_to
set.add name="ontology.star_names" id="word:ar:المراق_الدب"

def "word:ar:المرزم" "al-Mirzam, 'the herald' — the star that rises just before Sirius to announce it, in Canis Major; the source of the star-name Mirzam."
ln word:ar:المرزم astro:star:mirzam sys:refers_to
ln word:ar:المرزم astro:constellation:canis_major @names_part_of
set.add name="ontology.star_names" id="word:ar:المرزم"

def "word:ar:المرفق" "al-Mirfaq, 'the elbow' (of Perseus) — the brightest star of Perseus; the source of the star-name Mirfak."
ln word:ar:المرفق astro:star:mirfak sys:refers_to
ln word:ar:المرفق astro:constellation:perseus @names_part_of
ln word:ar:المرفق myth:greek_perseus_andromeda @related_to
set.add name="ontology.star_names" id="word:ar:المرفق"

def "word:ar:المركب" "al-Markab, 'the saddle' — a star of the Great Square, the mount of the winged horse Pegasus; the source of the star-name Markab."
ln word:ar:المركب astro:star:markab sys:refers_to
ln word:ar:المركب astro:constellation:pegasus @names_part_of
ln word:ar:المركب myth:greek_perseus_andromeda @related_to
set.add name="ontology.star_names" id="word:ar:المركب"

def "word:ar:المغرز" "al-Maghriz, 'the root of the tail' — where the Dipper's handle joins its bowl; the source of the star-name Megrez."
ln word:ar:المغرز astro:star:megrez sys:refers_to
ln word:ar:المغرز astro:constellation:ursa_major @names_part_of
set.add name="ontology.star_names" id="word:ar:المغرز"

def "word:ar:المنخر" "al-Minkhar, 'the nostril' (of the sea-monster) — a star in the head of Cetus; the source of the star-name Menkar."
ln word:ar:المنخر astro:star:menkar sys:refers_to
ln word:ar:المنخر astro:constellation:cetus @names_part_of
ln word:ar:المنخر myth:greek_perseus_andromeda @related_to
set.add name="ontology.star_names" id="word:ar:المنخر"

def "word:ar:المنطقة" "al-Minṭaqa, 'the belt' — one of the three stars of Orion's belt; the source of the star-name Mintaka."
ln word:ar:المنطقة astro:star:mintaka sys:refers_to
ln word:ar:المنطقة astro:constellation:orion @names_part_of
set.add name="ontology.star_names" id="word:ar:المنطقة"

def "word:ar:النطاق" "an-Niṭāq, 'the girdle' — the easternmost star of Orion's belt; the source of the star-name Alnitak."
ln word:ar:النطاق astro:star:alnitak sys:refers_to
ln word:ar:النطاق astro:constellation:orion @names_part_of
set.add name="ontology.star_names" id="word:ar:النطاق"

def "word:ar:النظام" "an-Niẓām, 'the string of pearls' — the central star of Orion's belt; the source of the star-name Alnilam."
ln word:ar:النظام astro:star:alnilam sys:refers_to
ln word:ar:النظام astro:constellation:orion @names_part_of
set.add name="ontology.star_names" id="word:ar:النظام"

def "word:ar:النير_الطائر" "an-Nayyir, 'the bright one' — the lead star of Grus the Crane, a constellation drawn only in the telescope age from the far-southern stars; the source of the star-name Alnair."
ln word:ar:النير_الطائر astro:star:alnair sys:refers_to
ln word:ar:النير_الطائر astro:constellation:grus @names_part_of
set.add name="ontology.star_names" id="word:ar:النير_الطائر"

def "word:ar:الهنعة" "al-Hanʿa, 'the brand-mark' — a star on the foot of the Twins; the source of the star-name Alhena. With Castor and Pollux the heads, the Twins are named head to foot."
ln word:ar:الهنعة astro:star:alhena sys:refers_to
ln word:ar:الهنعة astro:constellation:gemini @names_part_of
set.add name="ontology.star_names" id="word:ar:الهنعة"

def "word:ar:الوزن" "al-Wazn, 'the weight' — a heavy-seeming star low in the Great Dog; the source of the star-name Wezen."
ln word:ar:الوزن astro:star:wezen sys:refers_to
ln word:ar:الوزن astro:constellation:canis_major @names_part_of
set.add name="ontology.star_names" id="word:ar:الوزن"

def "word:ar:الية" "Alyah, 'the fat tail of the sheep' (or al-jawn, the black courser) — a star on the Dipper's handle; the source of the star-name Alioth."
ln word:ar:الية astro:star:alioth sys:refers_to
ln word:ar:الية astro:constellation:ursa_major @names_part_of
set.add name="ontology.star_names" id="word:ar:الية"

def "word:ar:اليد" "al-Yad, 'the hand' — the star at the hand of the Serpent-Bearer where he grips the snake, Ophiuchus; the source of the star-name Yed. With Rasalhague the head and Unukalhai the serpent's neck, the wrestling is named."
ln word:ar:اليد astro:star:yed_prior sys:refers_to
ln word:ar:اليد astro:constellation:ophiuchus @names_part_of
ln word:ar:اليد word:ar:رأس_الحواء @related_to
set.add name="ontology.star_names" id="word:ar:اليد"

def "word:ar:ذنب_الأسد" "Dhanab al-Asad, 'the tail of the lion' — the star at the tail of Leo; the source of the star-name Denebola. Its 'Deneb-' shares the root dhanab (tail) with Deneb of the Swan."
ln word:ar:ذنب_الأسد astro:star:denebola sys:refers_to
ln word:ar:ذنب_الأسد astro:constellation:leo @names_part_of
ln word:ar:ذنب_الأسد word:ar:ذنب_الدجاجة @related_to
set.add name="ontology.star_names" id="word:ar:ذنب_الأسد"

def "word:ar:ذنب_قيطس" "Dhanab Qayṭus, 'the tail of the sea-monster' — the star at the tail of Cetus, the beast Perseus slew; the source of the star-name Deneb Kaitos (Diphda). Another 'Deneb-', another tail."
ln word:ar:ذنب_قيطس astro:star:diphda sys:refers_to
ln word:ar:ذنب_قيطس astro:constellation:cetus @names_part_of
ln word:ar:ذنب_قيطس myth:greek_perseus_andromeda @related_to
set.add name="ontology.star_names" id="word:ar:ذنب_قيطس"

def "word:ar:رأس_الجاثي" "Raʾs al-Jāthī, 'the head of the kneeler' — the star at the head of the figure who kneels in the sky (Hercules); the source of the star-name Rasalgethi."
ln word:ar:رأس_الجاثي astro:star:rasalgethi sys:refers_to
ln word:ar:رأس_الجاثي astro:constellation:hercules @names_part_of
set.add name="ontology.star_names" id="word:ar:رأس_الجاثي"

def "word:ar:رأس_الحواء" "Raʾs al-Ḥawwāʾ, 'the head of the serpent-bearer' — the chief star of Ophiuchus, the man who grapples the great serpent across the sky; the source of the star-name Rasalhague."
ln word:ar:رأس_الحواء astro:star:rasalhague sys:refers_to
ln word:ar:رأس_الحواء astro:constellation:ophiuchus @names_part_of
set.add name="ontology.star_names" id="word:ar:رأس_الحواء"

def "word:ar:رجل_القنطورس" "Rijl al-Qanṭūrus, 'the foot of the Centaur' — one of the few southern stars an Arab name reached, the nearest star system to our own; the source of the name Rigil Kentaurus, Alpha Centauri."
ln word:ar:رجل_القنطورس astro:star:rigil_kentaurus sys:refers_to
ln word:ar:رجل_القنطورس astro:constellation:centaurus @names_part_of
set.add name="ontology.star_names" id="word:ar:رجل_القنطورس"

def "word:ar:سعد_السعود" "Saʿd as-Suʿūd, 'luckiest of the lucky' — a star of Aquarius, counted most fortunate by the old Arab star-watchers; the source of the star-name Sadalsuud."
ln word:ar:سعد_السعود astro:star:sadalsuud sys:refers_to
ln word:ar:سعد_السعود astro:constellation:aquarius @names_part_of
set.add name="ontology.star_names" id="word:ar:سعد_السعود"

def "word:ar:سعد_الملك" "Saʿd al-Malik, 'the luck of the king' — a fortunate star of Aquarius; the source of the star-name Sadalmelik. It stands beside Sadalsuud, 'the luckiest of the lucky', among the old Arab stars of good fortune."
ln word:ar:سعد_الملك astro:star:sadalmelik sys:refers_to
ln word:ar:سعد_الملك astro:constellation:aquarius @names_part_of
ln word:ar:سعد_الملك word:ar:سعد_السعود @related_to
set.add name="ontology.star_names" id="word:ar:سعد_الملك"

def "word:ar:سهيل" "Suhayl — the Arabic name for Canopus, a great star of the far south used in navigation and praised in poetry; cognate with the personal name Suhail."
ln word:ar:سهيل astro:star:canopus sys:refers_to
set.add name="ontology.star_names" id="word:ar:سهيل"

def "word:ar:سيف" "Saif, 'the sword' (from saif al-jabbār, the giant's sword) — the row of stars hanging from Orion's belt; the source of the star-name Saiph."
ln word:ar:سيف astro:star:saiph sys:refers_to
ln word:ar:سيف astro:constellation:orion @names_part_of
set.add name="ontology.star_names" id="word:ar:سيف"

def "word:ar:عنق_الحية" "ʿUnuq al-Ḥayya, 'the serpent's neck' — the bright star in the coils of Serpens, the great snake gripped by the Serpent-Bearer Ophiuchus; the source of the star-name Unukalhai."
ln word:ar:عنق_الحية astro:star:unukalhai sys:refers_to
ln word:ar:عنق_الحية astro:constellation:serpens @names_part_of
ln word:ar:عنق_الحية word:ar:رأس_الحواء @related_to
set.add name="ontology.star_names" id="word:ar:عنق_الحية"

def "word:ar:قوس" "Qaws, 'the bow' — the star at the drawn bow of the celestial Archer; the source of the star-name Kaus (Kaus Australis, the southern part of the bow) in Sagittarius."
ln word:ar:قوس astro:star:kaus_australis sys:refers_to
ln word:ar:قوس astro:constellation:sagittarius @names_part_of
ln word:ar:قوس myth:greek_chiron_archer @related_to
set.add name="ontology.star_names" id="word:ar:قوس"

def "word:ar:مئزر" "Miʾzar, 'the waistband' — the middle star of the Great Bear's tail (the Big Dipper's handle); the source of the star-name Mizar."
ln word:ar:مئزر astro:star:mizar sys:refers_to
ln word:ar:مئزر astro:constellation:ursa_major @names_part_of
set.add name="ontology.star_names" id="word:ar:مئزر"

def "word:ar:منازل_القمر" "Manāzil al-Qamar, 'the stations of the Moon' — the twenty-eight resting-places of the Moon along its monthly path in Arabic astronomy. With the Chinese twenty-eight mansions and the Indian Nakshatra, it is one of three great traditions that quartered the lunar sky into some twenty-seven or twenty-eight lodges."
ln word:ar:منازل_القمر star_name @related_to
ln word:ar:منازل_القمر word:sa:nakshatra @parallels
ln word:ar:منازل_القمر myth:chinese_four_symbols @parallels
set.add name="ontology.star_names" id="word:ar:منازل_القمر"

def "word:ar:منكب_ذي_العنان" "Mankib dhī al-ʿInān, 'the shoulder of the rein-holder' — the shoulder-star of the Charioteer, Auriga; the source of the star-name Menkalinan. With Capella the she-goat on his arm, the Charioteer is named."
ln word:ar:منكب_ذي_العنان astro:star:menkalinan sys:refers_to
ln word:ar:منكب_ذي_العنان astro:constellation:auriga @names_part_of
set.add name="ontology.star_names" id="word:ar:منكب_ذي_العنان"

def "word:ar:نير_الفكة" "Nayyir al-Fakka, 'the bright one of the broken ring' — the gem of the Northern Crown; the source of the star-name Alphecca."
ln word:ar:نير_الفكة astro:star:alphecca sys:refers_to
ln word:ar:نير_الفكة astro:constellation:corona_borealis @names_part_of
ln word:ar:نير_الفكة myth:greek_ariadne_crown @related_to
set.add name="ontology.star_names" id="word:ar:نير_الفكة"

def "word:ar:هدار" "Hadār — an old Arabic star-name, 'the ground' or a settled lowland, for the bright blue star of the Centaur beside Rigil Kentaurus; the source of the star-name Hadar (also called Agena)."
ln word:ar:هدار astro:star:hadar sys:refers_to
ln word:ar:هدار astro:constellation:centaurus @names_part_of
set.add name="ontology.star_names" id="word:ar:هدار"

def "word:cy:caer_arianrhod" "Caer Arianrhod, 'the fortress of Arianrhod' — the Welsh name for the Northern Crown, the sky-castle of the goddess; the same ring of stars Greek tradition made Ariadne's bridal crown."
ln word:cy:caer_arianrhod astro:constellation:corona_borealis sys:refers_to
ln word:cy:caer_arianrhod myth:greek_ariadne_crown @related_to
set.add name="ontology.star_names" id="word:cy:caer_arianrhod"

def "word:egy:meskhetiu" "Meskhetiu, 'the Bull's Foreleg' (also the Adze) — the Egyptian figure on the seven northern stars: the Greek Bear, the Chinese Dipper of fate, the Arabic bier of mourners, an Egyptian foreleg of sacrifice, all one circling asterism."
ln word:egy:meskhetiu astro:constellation:ursa_major sys:refers_to
ln word:egy:meskhetiu myth:greek_callisto_bear @related_to
ln word:egy:meskhetiu word:ar:القائد @related_to
set.add name="ontology.star_names" id="word:egy:meskhetiu"

def "word:egy:sah" "Sah — the Egyptian Orion, the celestial form of Osiris, lord of the dead, striding across the southern sky beside his consort-star Sopdet."
ln word:egy:sah astro:constellation:orion sys:refers_to
ln word:egy:sah myth:egyptian_osiris @related_to
ln word:egy:sah word:akk:true_shepherd @related_to
set.add name="ontology.star_names" id="word:egy:sah"

def "word:egy:sopdet" "Sopdet — the Egyptian Sirius, the goddess identified with Isis; her dawn rising after weeks of absence heralded the flooding of the Nile and the turning of the year, beside Sah-Osiris in the sky."
ln word:egy:sopdet astro:star:sirius sys:refers_to
