def "word:en:wireless" "Communication without physical cables using radio waves."
ln word:en:wireless networking.wireless sys:associated_with
set.add name="ontology.networking" id="word:en:wireless"

def "word:en:wise" "Having or showing experience, knowledge, and good judgment."

def "word:en:wither" "(Of a plant) become dry and shriveled."

def "word:en:wms" "Warehouse Management System."
ln word:en:wms atr.warehouse_automation sys:associated_with
ln word:en:wms atr:asrs @controls
set.add name="ontology.autonomous_transport" id="word:en:wms"

def "word:en:wolf_in_sheeps_clothing" "Idiom: a danger or hostility disguised as harmless or friendly — from Aesop."
ln word:en:wolf_in_sheeps_clothing tale:aesop_wolf_sheeps_clothing sys:refers_to

def "word:en:work" "Activity involving mental or physical effort done in order to achieve a purpose or result."

def "word:en:workflow" "The sequence of tasks through which work passes."
ln word:en:workflow manufacturing.process sys:associated_with
set.add name="ontology.manufacturing" id="word:en:workflow"

def "word:en:world" "A self-consistent reality — physical, fictional, or conceptual."
ln word:en:world fantasy.category.world_type sys:associated_with
set.add name="ontology.entertainment_fantasy" id="word:en:world"

def "word:en:worsen" "Make or become worse."

def "word:en:wrap" "Cover or enclose (someone or something) in paper or soft material."

def "word:en:writer" "One who writes."
ln word:en:writer writing.roles sys:is_a
set.add name="ontology.writing" id="word:en:writer"

def "word:en:wrong" "Not correct or true; incorrect."

def "word:en:yield" "Give way to arguments, demands, or pressure."

def "word:en:young" "Having lived or existed for only a short time."

def "word:en:youthful" "Young or seeming young."

def "word:en:zarathustra" "Zarathustra (Zoroaster) — the prophet of ancient Iran who taught the worship of Ahura Mazda alone as the source of good, and framed life as a free choice between truth and the lie; the Greeks knew him as Zoroaster."
ln word:en:zarathustra myth:zoroastrian_pantheon @related_to
set.add name="ontology.zoroastrian" id="word:en:zarathustra"

def "word:en:zenith" "The time at which something is most powerful or successful."

def "word:en:zero_trust" "Security model assuming no implicit trust in any network component."
ln word:en:zero_trust cloud_networking.security sys:associated_with
set.add name="ontology.cloud_networking" id="word:en:zero_trust"

def "word:en:zhuangzi" "Zhuangzi (c. 4th c. BCE), foundational Daoist thinker and the text bearing his name, rich in parable and paradox."

def "word:en:zoom" "A change of focal length toward or away from a subject."
ln word:en:zoom writing.cinematic sys:is_a
ln word:en:zoom word:en:shot @related_to
set.add name="ontology.writing" id="word:en:zoom"

def "word:en:zos" "IBM z/OS mainframe operating system."
ln word:en:zos mfos.ibm sys:associated_with
set.add name="ontology.mainframe_os" id="word:en:zos"

def "word:fa:ترازو" "Tarāzū, 'the beam of the balance' — a Persian name for the line of stars about Altair that seemed a weigh-beam; the source of the star-name Tarazed."
ln word:fa:ترازو astro:star:tarazed sys:refers_to
ln word:fa:ترازو astro:constellation:aquila @names_part_of
set.add name="ontology.star_names" id="word:fa:ترازو"

def "word:fa:شاهین" "Shāhīn, 'the royal falcon' — a Persian name for the bird-figure beside Altair, surviving in the star-name Alshain in the Eagle, Aquila. A reminder that not all the oriental star-names are Arabic; Persian named the sky too."
ln word:fa:شاهین astro:star:alshain sys:refers_to
ln word:fa:شاهین astro:constellation:aquila @names_part_of
set.add name="ontology.star_names" id="word:fa:شاهین"

def "word:grc:zosma" "Zōsma, Greek 'the girdle' — the star on the Lion's back or loins; one of the few star-names taken straight from Greek. With Regulus, Algieba, and Denebola, the Lion is named heart to tail."
ln word:grc:zosma astro:star:zosma sys:refers_to
ln word:grc:zosma astro:constellation:leo @names_part_of
set.add name="ontology.star_names" id="word:grc:zosma"

def "word:haw:hokulea" "Hōkūleʻa, 'Star of Gladness' — the Hawaiian name for Arcturus, which passes through the zenith over Hawaiʻi and so guided voyagers home; the great voyaging canoe is named for it. The same star is the Greek Bear-guard and the Chinese Great Horn."
ln word:haw:hokulea astro:star:arcturus sys:refers_to
ln word:haw:hokulea word:la:arcturus @related_to
ln word:haw:hokulea word:zh:大角 @related_to
set.add name="ontology.star_names" id="word:haw:hokulea"

def "word:haw:hokupaa" "Hōkūpaʻa, 'the Fixed Star' — the Hawaiian name for Polaris, the one star that does not move, by which the northern course was held."
ln word:haw:hokupaa astro:star:polaris sys:refers_to
ln word:haw:hokupaa word:la:polaris @related_to
set.add name="ontology.star_names" id="word:haw:hokupaa"

def "word:he:כימה" "Kimah — the Hebrew name for the Pleiades, named in the Book of Job ('Canst thou bind the sweet influences of Kimah?'); one more people gathered on that small cluster of stars."
ln word:he:כימה astro:constellation:taurus sys:refers_to
ln word:he:כימה pleiades sys:refers_to
ln word:he:כימה myth:greek_pleiades @related_to
ln word:he:כימה word:akk:sebettu @related_to
set.add name="ontology.star_names" id="word:he:כימה"

def "word:he:כסיל" "Kesil, 'the fool' — the Hebrew name for Orion in the Book of Job, pictured as a rebel giant bound fast in the sky ('or loose the bands of Kesil')."
ln word:he:כסיל astro:constellation:orion sys:refers_to
ln word:he:כסיל myth:greek_orion @related_to
set.add name="ontology.star_names" id="word:he:כסיל"

def "word:he:מזרות" "Mazzaroth — the Hebrew word in Job for the constellations of the zodiac brought forth each in its season; the band of signs the Babylonians first marked out."
ln word:he:מזרות zodiac @explains
ln word:he:מזרות myth:babylonian_sky_origin @related_to
set.add name="ontology.star_names" id="word:he:מזרות"

def "word:he:עיש" "Ayish (Ash) — the Hebrew name in Job for the great northern stars, 'the Bear with her children', the same seven that are elsewhere the Dipper, the Wain, and the Bull's foreleg."
ln word:he:עיש astro:constellation:ursa_major sys:refers_to
ln word:he:עיש myth:greek_callisto_bear @related_to
set.add name="ontology.star_names" id="word:he:עיש"

def "word:ja:三つ星" "Mitsuboshi, 'the three stars' — the Japanese folk name for the three stars of Orion's belt that Arabic tradition named the Belt, the Girdle, and the String of Pearls."
ln word:ja:三つ星 astro:constellation:orion @names_part_of
ln word:ja:三つ星 word:ar:المنطقة @related_to
set.add name="ontology.star_names" id="word:ja:三つ星"

def "word:ja:昔話" "Mukashibanashi: the traditional Japanese folktale, opening 'mukashi mukashi' (long, long ago) and closing on a turn of fortune or a moral."

def "word:ja:鼓星" "Tsuzumiboshi, 'the drum star' — a Japanese folk name for Orion, whose hourglass of bright stars was seen as the shape of a hand-drum."
ln word:ja:鼓星 astro:constellation:orion sys:refers_to
set.add name="ontology.star_names" id="word:ja:鼓星"

def "word:la:albireo" "Albireo — the lovely double star at the head of the Swan, whose name means nothing at all: it is a chain of copying mistakes, a Greek word for 'bird' mangled through Arabic into a Latin herbal misreading, ab ireo. A name with no meaning that yet IS a name — the bare word in its purest form."
ln word:la:albireo astro:star:albireo sys:refers_to
ln word:la:albireo astro:constellation:cygnus @names_part_of
set.add name="ontology.star_names" id="word:la:albireo"

def "word:la:antares" "Greek Antares, 'rival of Ares (Mars)' — the red heart of the Scorpion, so named because its colour vies with the planet Mars; the source of the star-name Antares."
ln word:la:antares astro:star:antares sys:refers_to
ln word:la:antares astro:constellation:scorpius @names_part_of
ln word:la:antares myth:greek_celestial_scorpion @related_to
set.add name="ontology.star_names" id="word:la:antares"

def "word:la:arcturus" "Greek Arktouros, 'guardian of the bear' — the bright star of Boötes that follows the Great Bear around the pole; the source of the star-name Arcturus."
ln word:la:arcturus astro:star:arcturus sys:refers_to
ln word:la:arcturus astro:constellation:bootes @names_part_of
ln word:la:arcturus myth:greek_callisto_bear @related_to
set.add name="ontology.star_names" id="word:la:arcturus"

def "word:la:asellus" "Asellus, 'the little ass' — the two stars, the Northern and the Southern Ass, that feed at the Manger; in Greek tale, the asses the gods rode into battle against the giants, set in the sky beside their crib."
ln word:la:asellus astro:constellation:cancer @names_part_of
ln word:la:asellus word:la:praesepe @related_to
set.add name="ontology.star_names" id="word:la:asellus"

def "word:la:bellatrix" "Latin 'the female warrior' — the star at Orion's left shoulder; one of the few star-names that is Latin rather than Arabic in origin."
ln word:la:bellatrix astro:star:bellatrix sys:refers_to
ln word:la:bellatrix astro:constellation:orion @names_part_of
set.add name="ontology.star_names" id="word:la:bellatrix"

def "word:la:capella" "Latin 'the little she-goat' — the bright star carried as a goat on the arm of the Charioteer, Auriga; the source of the star-name Capella."
ln word:la:capella astro:star:capella sys:refers_to
ln word:la:capella astro:constellation:auriga @names_part_of
set.add name="ontology.star_names" id="word:la:capella"

def "word:la:hyades" "The Hyades, 'the rainy ones' — the V of stars that make the face of the Bull, half-sisters of the Pleiades; the Greeks said they wept so for their dead brother that their rising still brings the rains. With Aldebaran their red eye and the Pleiades on the shoulder, the Bull's head is wholly storied."
ln word:la:hyades astro:constellation:taurus @names_part_of
ln word:la:hyades myth:greek_pleiades @related_to
ln word:la:hyades word:ar:الدبران @related_to
set.add name="ontology.star_names" id="word:la:hyades"

def "word:la:jupiter" "Jupiter — named for the king of the Roman gods, Jove, for Greek Zeus; the greatest and most lordly of the wandering stars."
ln word:la:jupiter jupiter sys:refers_to
set.add name="ontology.planet_names" id="word:la:jupiter"

def "word:la:lucifer" "Lucifer, 'the light-bearer' — the Latin name for the morning star, Venus rising before the sun; a name born from describing the thing it names."
ln word:la:lucifer venus sys:refers_to
ln word:la:lucifer myth:greek_venus_twin @related_to
set.add name="ontology.star_names" id="word:la:lucifer"

def "word:la:luna" "Luna — the Latin name of the Moon, the root of lunar and of Monday, dies Lunae; the Norse called him Máni, fleeing his own pursuing wolf. The second of the seven lights, and the second day of the week."
ln word:la:luna moon sys:refers_to
ln word:la:luna word:en:weekday_names @related_to
ln word:la:luna myth:norse_sun_wolves @related_to
set.add name="ontology.planet_names" id="word:la:luna"

def "word:la:mars" "Mars — named for the Roman god of war, for its blood-red colour; the red star Antares takes its name from being its rival, anti-Ares, the Greek war-god's match."
ln word:la:mars mars sys:refers_to
ln word:la:mars word:la:antares @related_to
set.add name="ontology.planet_names" id="word:la:mars"

def "word:la:mercury" "Mercury — named for the Roman god of messengers and trade, for Greek Hermes, because it is the swiftest wanderer, never straying far from the sun."
ln word:la:mercury mercury sys:refers_to
set.add name="ontology.planet_names" id="word:la:mercury"

def "word:la:mira" "Mira, 'the wonderful' — the Latin name given to the star in Cetus that fades from sight and returns over months, the first variable star recognised in the West; named for the marvel of a star that comes and goes."
ln word:la:mira astro:star:mira sys:refers_to
ln word:la:mira astro:constellation:cetus @names_part_of
ln word:la:mira wonder @illustrates
set.add name="ontology.star_names" id="word:la:mira"

def "word:la:polaris" "Latin 'the star of the pole' — the present North Star, near the celestial pole in the Little Bear. A relatively late name: through the slow wheel of precession it was not the pole star in antiquity and will not always be."
ln word:la:polaris astro:star:polaris sys:refers_to
ln word:la:polaris astro:constellation:ursa_minor @names_part_of
set.add name="ontology.star_names" id="word:la:polaris"

def "word:la:praesepe" "Praesepe, 'the manger' — the misty star-cluster at the heart of the Crab, seen since antiquity as a crib of hay; its dimming or clearing was read as a sign of the coming weather."
ln word:la:praesepe astro:constellation:cancer @names_part_of
ln word:la:praesepe myth:greek_cancer_crab @related_to
set.add name="ontology.star_names" id="word:la:praesepe"

def "word:la:procyon" "Greek Prokyōn, 'before the dog' — the star that rises just before Sirius, the lesser dog-star of Canis Minor; the source of the star-name Procyon."
ln word:la:procyon astro:star:procyon sys:refers_to
ln word:la:procyon astro:constellation:canis_minor @names_part_of
set.add name="ontology.star_names" id="word:la:procyon"

def "word:la:regulus" "Latin 'the little king' — the heart of the Lion, called the royal star since Babylonian times; the source of the star-name Regulus."
ln word:la:regulus astro:star:regulus sys:refers_to
ln word:la:regulus astro:constellation:leo @names_part_of
ln word:la:regulus myth:greek_nemean_lion @related_to
set.add name="ontology.star_names" id="word:la:regulus"

def "word:la:saturn" "Saturn — named for the old Roman god, for Greek Kronos; the slowest and farthest of the wanderers the ancients could see, plodding the long circle of the sky."
ln word:la:saturn saturn sys:refers_to
set.add name="ontology.planet_names" id="word:la:saturn"

def "word:la:sirius" "Latin Sirius, from Greek Seirios, 'the scorcher / the glowing' — the brightest star in the sky, in Canis Major, the Dog Star. To the Egyptians it was Sopdet, whose dawn rising heralded the flooding of the Nile."
ln word:la:sirius astro:star:sirius sys:refers_to
ln word:la:sirius astro:constellation:canis_major @names_part_of
ln word:la:sirius flood @related_to
set.add name="ontology.star_names" id="word:la:sirius"

def "word:la:sol" "Sol — the Latin name of the Sun, the root of solar and of Sunday, dies Solis; the Norse called her Sól, the bright goddess driven forever across the sky by the wolf that would devour her. The first of the seven 'planets', and the first day of the week."
ln word:la:sol sun sys:refers_to
ln word:la:sol word:en:weekday_names @related_to
ln word:la:sol myth:norse_sun_wolves @related_to
set.add name="ontology.planet_names" id="word:la:sol"

def "word:la:spica" "Latin 'the ear of grain' — the bright star held as a sheaf of wheat in the hand of the maiden Virgo; the source of the star-name Spica."
ln word:la:spica astro:star:spica sys:refers_to
ln word:la:spica astro:constellation:virgo @names_part_of
ln word:la:spica myth:greek_astraea @related_to
set.add name="ontology.star_names" id="word:la:spica"

def "word:la:venus" "Venus — named for the Roman goddess of love, for it is the brightest and loveliest of the wandering stars, the morning and evening star the Babylonians knew as Ishtar."
ln word:la:venus venus sys:refers_to
set.add name="ontology.planet_names" id="word:la:venus"

def "word:la:vindemiatrix" "Vindemiatrix, 'the grape-gatherer' — a star of Virgo whose rising before dawn told the ancients the vintage was at hand; a star that named the season for the harvest of the vine."
ln word:la:vindemiatrix astro:star:vindemiatrix sys:refers_to
ln word:la:vindemiatrix astro:constellation:virgo @names_part_of
set.add name="ontology.star_names" id="word:la:vindemiatrix"

def "word:mi:atutahi" "Atutahi — the Maori name for Canopus, the 'first-born', a sacred chief-star set apart from the Milky Way; the Arabs steered by it as Suhayl and the Chinese honoured it as the Old Man of longevity."
ln word:mi:atutahi astro:star:canopus sys:refers_to
ln word:mi:atutahi word:ar:سهيل @related_to
ln word:mi:atutahi word:zh:老人 @related_to
set.add name="ontology.star_names" id="word:mi:atutahi"

def "word:mi:matariki" "Matariki — the Maori name for the Pleiades, whose dawn rising in midwinter opens the Maori New Year, a time of remembrance and renewal. Greek, Babylonian, Indian, Japanese, Aboriginal, and Maori skies all gather on this one cluster."
ln word:mi:matariki astro:constellation:taurus sys:refers_to
ln word:mi:matariki pleiades sys:refers_to
ln word:mi:matariki myth:greek_pleiades @related_to
ln word:mi:matariki word:akk:sebettu @related_to
ln word:mi:matariki myth:aboriginal_seven_sisters @related_to
set.add name="ontology.star_names" id="word:mi:matariki"

def "word:mi:tautoru" "Tautoru, 'the three' — the Maori name for the three stars of Orion's belt, the Japanese 'three stars' and the Arabic Belt and String of Pearls of the same row."
ln word:mi:tautoru astro:constellation:orion @names_part_of
ln word:mi:tautoru word:ja:三つ星 @related_to
set.add name="ontology.star_names" id="word:mi:tautoru"

def "word:mi:te_punga" "Te Punga, 'the anchor' — the Maori name for the Southern Cross, the anchor-stone of the great sky-canoe of Tama-rereti that holds the heavens steady; by it the navigators held their course."
ln word:mi:te_punga astro:constellation:crux sys:refers_to
ln word:mi:te_punga word:en:southern_cross @related_to
set.add name="ontology.star_names" id="word:mi:te_punga"

def "word:non:aurvandil_toe" "Aurvandils-tá, 'Aurvandil's toe' — in the Prose Edda, Thor casts the frozen toe of Aurvandil into the heavens, where it becomes a star (which one, the saga does not say). A rare named star of Norse myth."
ln word:non:aurvandil_toe stars @explains
set.add name="ontology.star_names" id="word:non:aurvandil_toe"

def "word:non:friggs_distaff" "Friggjarrokkr, 'Frigg's distaff' — the Scandinavian name for the three stars of Orion's belt, seen as the spindle-staff of the goddess; the same row the Arabs called the Belt and the Maori 'the three'."
ln word:non:friggs_distaff astro:constellation:orion @names_part_of
ln word:non:friggs_distaff word:mi:tautoru @related_to
set.add name="ontology.star_names" id="word:non:friggs_distaff"

def "word:sa:chitra" "Citrā, 'the bright one' — the Nakshatra marked by Spica, the star the Romans named the ear of grain in the Maiden's hand."
ln word:sa:chitra astro:star:spica sys:refers_to
ln word:sa:chitra word:la:spica @related_to
set.add name="ontology.star_names" id="word:sa:chitra"

def "word:sa:jyeshtha" "Jyeṣṭhā, 'the eldest' — the Nakshatra marked by Antares, the red heart of the Scorpion, the senior and chief; the same star the Greeks called the rival of Mars and the Chinese the Heart-mansion."
ln word:sa:jyeshtha astro:star:antares sys:refers_to
ln word:sa:jyeshtha word:la:antares @related_to
ln word:sa:jyeshtha word:zh:心宿二 @related_to
set.add name="ontology.star_names" id="word:sa:jyeshtha"

def "word:sa:krittika" "Kṛttikā — the Nakshatra of the Pleiades, the six (or seven) mothers who nursed the war-god Kartikeya. The same cluster is the Greek and Aboriginal seven sisters and the Japanese Subaru: four skies on one knot of stars."
ln word:sa:krittika astro:constellation:taurus sys:refers_to
ln word:sa:krittika pleiades sys:refers_to
ln word:sa:krittika myth:greek_pleiades @related_to
ln word:sa:krittika myth:japanese_subaru @related_to
ln word:sa:krittika myth:aboriginal_seven_sisters @related_to
set.add name="ontology.star_names" id="word:sa:krittika"

def "word:sa:magha" "Maghā, 'the bountiful / the throne' — the Nakshatra marked by Regulus, seat of kings; royal in the Indian, Babylonian, Roman, and Chinese skies alike."
ln word:sa:magha astro:star:regulus sys:refers_to
ln word:sa:magha word:la:regulus @related_to
set.add name="ontology.star_names" id="word:sa:magha"

def "word:sa:nakshatra" "Nakṣatra — the twenty-seven (sometimes twenty-eight) lunar mansions of Indian astronomy, the segments of the Moon's monthly path, each marked by a star or asterism and woven into a deep tradition of myth and reckoning."
ln word:sa:nakshatra star_name @related_to
set.add name="ontology.star_names" id="word:sa:nakshatra"

def "word:sa:rohini" "Rohiṇī, 'the red one' — the Nakshatra marked by Aldebaran, beloved consort of Chandra the Moon, for whom he lingers; the same red star the Arabs called 'the follower'."
ln word:sa:rohini astro:star:aldebaran sys:refers_to
ln word:sa:rohini word:ar:الدبران @related_to
set.add name="ontology.star_names" id="word:sa:rohini"

def "word:uk:volosozhary" "Volosozhary (also Stozhary) — a Slavic name for the Pleiades; with the Greek sisters, the Indian Krittika, the Arabic Thurayya, the Babylonian Seven, and the Maori Matariki, one more reading of the little cluster."
ln word:uk:volosozhary astro:constellation:taurus sys:refers_to
ln word:uk:volosozhary pleiades sys:refers_to
ln word:uk:volosozhary myth:greek_pleiades @related_to
set.add name="ontology.star_names" id="word:uk:volosozhary"

def "word:wdj:collowgullouric_war" "Collowgullouric War — the Boorong name for the great red star in the Keel, the wife of War the Crow (Canopus); it is identified with Eta Carinae, which in the 1840s flared into one of the brightest stars in the sky and then faded — a star whose change the Boorong saw and named. — Boorong (Wergaia), rec. Stanbridge 1857"
ln word:wdj:collowgullouric_war astro:constellation:carina @related_to
ln word:wdj:collowgullouric_war wonder @illustrates
set.add name="ontology.star_names" id="word:wdj:collowgullouric_war"

def "word:wdj:marpeankurrk" "Marpeankurrk — the Boorong name for Arcturus, a mother of the ancestral time who found the wood-ant larvae that fed the people through a hard season; when her star stands in the evening, it is the time to dig them. — Boorong (Wergaia), rec. Stanbridge 1857"
ln word:wdj:marpeankurrk astro:star:arcturus sys:refers_to
set.add name="ontology.star_names" id="word:wdj:marpeankurrk"

def "word:wdj:neilloan" "Neilloan, 'the mallee-fowl' — to the Boorong, the star Vega in the Lyre is the mallee-fowl whose rising in autumn tells when to gather her eggs; a star read as a season. The Greeks heard a lyre here; the Boorong, a nesting bird. — Boorong (Wergaia), rec. Stanbridge 1857"
ln word:wdj:neilloan astro:star:vega sys:refers_to
ln word:wdj:neilloan astro:constellation:lyra @related_to
ln word:wdj:neilloan myth:greek_orpheus_lyre @related_to
set.add name="ontology.star_names" id="word:wdj:neilloan"

def "word:wdj:totyarguil" "Totyarguil — the Boorong name for Altair, a hero of the ancestral time, the two stars at his sides his two wives; the same lone bright star the Arabs called the Flying Eagle and the Chinese the Cowherd. — Boorong (Wergaia), rec. Stanbridge 1857"
ln word:wdj:totyarguil astro:star:altair sys:refers_to
set.add name="ontology.star_names" id="word:wdj:totyarguil"

def "word:wdj:warepil" "Warepil — the Boorong name for Sirius, the Wedge-tailed Eagle, a great chief of the sky; the brightest star is a leader here as it was the Dog, the Wolf, and the Arrow elsewhere. — Boorong (Wergaia), rec. Stanbridge 1857"
ln word:wdj:warepil astro:star:sirius sys:refers_to
set.add name="ontology.star_names" id="word:wdj:warepil"

def "word:zh:井底之蛙" "Idiom 'a frog at the bottom of a well': one of narrow experience who mistakes their small world for the whole — from the Zhuangzi."
ln word:zh:井底之蛙 tale:china_frog_well sys:refers_to

def "word:zh:土星" "Tǔxīng, 'the Earth Star' — the Chinese name for Saturn, slowest of the five, matched to the steady phase of earth."
ln word:zh:土星 saturn sys:refers_to
ln word:zh:土星 word:la:saturn @related_to
set.add name="ontology.planet_names" id="word:zh:土星"

def "word:zh:塞翁失马" "Idiom 'the old frontiersman loses his horse': a blessing in disguise; fortune and misfortune are hard to tell apart — from the Huainanzi."
ln word:zh:塞翁失马 tale:china_old_man_horse sys:refers_to

def "word:zh:大角" "Dàjiǎo, 'the Great Horn' — the Chinese name for Arcturus, which the Greeks called the Guardian of the Bear; a herald star of the eastern sky."
ln word:zh:大角 astro:star:arcturus sys:refers_to
ln word:zh:大角 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:大角"

def "word:zh:天狼" "Tiānláng, 'the Celestial Wolf' — the Chinese name for the brightest star, which the Greeks called the Scorching Dog-Star and the Egyptians Sopdet of the Nile flood; one star, three skies."
ln word:zh:天狼 astro:star:sirius sys:refers_to
ln word:zh:天狼 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:天狼"

def "word:zh:守株待兔" "Idiom 'guarding a stump, waiting for a hare': trusting to a lucky fluke instead of honest effort — from the Han Feizi."
ln word:zh:守株待兔 tale:china_waiting_stump sys:refers_to

def "word:zh:心宿二" "Xīnxiù'èr, 'the Second Star of the Heart mansion' — the Chinese name for the red star the Greeks called Antares, the rival of Mars; the fiery heart of the Scorpion in both skies."
ln word:zh:心宿二 astro:star:antares sys:refers_to
ln word:zh:心宿二 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:心宿二"

def "word:zh:星官" "Xīngguān, the Chinese asterisms — the sky mapped as a celestial bureaucracy of emperors, officials, rivers, and granaries within three enclosures and twenty-eight mansions; a naming logic of earthly order rather than mythic figures."
set.add name="ontology.star_names" id="word:zh:星官"

def "word:zh:木星" "Mùxīng, 'the Wood Star' — the Chinese name for Jupiter, the great slow planet that the Chinese also used to count the years in a twelve-year cycle."
ln word:zh:木星 jupiter sys:refers_to
ln word:zh:木星 word:la:jupiter @related_to
set.add name="ontology.planet_names" id="word:zh:木星"

def "word:zh:杞人忧天" "Idiom 'the man of Qi who feared the sky would fall': needless worry over impossible disasters — from the Liezi."
ln word:zh:杞人忧天 tale:china_qi_sky sys:refers_to

def "word:zh:水星" "Shuǐxīng, 'the Water Star' — the Chinese name for Mercury. China named the five wanderers not for gods but for the Five Phases: water, metal, fire, wood, earth."
ln word:zh:水星 mercury sys:refers_to
ln word:zh:水星 word:la:mercury @related_to
set.add name="ontology.planet_names" id="word:zh:水星"

def "word:zh:火星" "Huǒxīng, 'the Fire Star' — the Chinese name for Mars; fire for the same red glow the Romans gave their war-god and the Greeks named the rival of Antares."
ln word:zh:火星 mars sys:refers_to
ln word:zh:火星 word:la:mars @related_to
set.add name="ontology.planet_names" id="word:zh:火星"

def "word:zh:牛郎" "Niúláng, 'the Cowherd' (the River-Drum star, Hégǔ) — the Chinese name for Altair, which the Arabs and Greeks alike saw as an eagle; here the herdsman who may cross to the Weaver but once a year."
ln word:zh:牛郎 astro:star:altair sys:refers_to
ln word:zh:牛郎 myth:chinese_qixi @related_to
ln word:zh:牛郎 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:牛郎"

def "word:zh:画蛇添足" "Idiom 'drawing a snake and adding feet': ruining a thing by needless addition — from the Zhanguo Ce."
ln word:zh:画蛇添足 tale:china_snake_feet sys:refers_to

def "word:zh:矛盾" "Contradiction (literally 'spear and shield'): a self-defeating inconsistency — from the Han Feizi tale of the vendor whose spear pierces any shield and whose shield stops any spear."
ln word:zh:矛盾 tale:china_self_contradiction sys:refers_to
ln word:zh:矛盾 contradiction sys:refers_to

def "word:zh:織女" "Zhīnǚ, 'the Weaver Girl' — the Chinese name for Vega, the same star the Arabs called the swooping eagle and the Greeks the lyre of Orpheus; here she is parted from the Cowherd by the Milky Way."
ln word:zh:織女 astro:star:vega sys:refers_to
ln word:zh:織女 myth:chinese_qixi @related_to
ln word:zh:織女 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:織女"

def "word:zh:老人" "Lǎorén, 'the Old Man' — the Chinese name for Canopus, the great southern star, embodied as the god of longevity of the South Pole; the same star the Arabs called Suhayl and steered by."
ln word:zh:老人 astro:star:canopus sys:refers_to
ln word:zh:老人 longevity @illustrates
ln word:zh:老人 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:老人"

def "word:zh:軒轅十四" "Xuānyuán shísì, 'the Fourteenth Star of the Yellow Emperor' — the Chinese name for Regulus, the star Western tradition crowned the Little King; royalty in both skies."
ln word:zh:軒轅十四 astro:star:regulus sys:refers_to
ln word:zh:軒轅十四 星官 sys:part_of
set.add name="ontology.star_names" id="word:zh:軒轅十四"

def "word:zh:金星" "Jīnxīng, 'the Metal Star' — the Chinese name for Venus; gold and metal for the white brilliance of the evening star."
ln word:zh:金星 venus sys:refers_to
ln word:zh:金星 word:la:venus @related_to
set.add name="ontology.planet_names" id="word:zh:金星"
