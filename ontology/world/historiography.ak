# Akasha ontology — namespace: historiography
# atoms: 6

def "historiography.archive" "Archives, records, testimony, and preservation of historical traces."
ln historiography.archive ont.historiography sys:part_of
set.add name="ontology.historiography" id="historiography.archive"

def "historiography.memory" "Collective memory, remembrance, forgetting, and commemoration."
ln historiography.memory ont.historiography sys:part_of
set.add name="ontology.historiography" id="historiography.memory"

