ln historiography.method ont.historiography sys:part_of
set.add name="ontology.historiography" id="historiography.method"

def "historiography.period" "Historical periods, epochs, and temporal divisions."
ln historiography.period ont.historiography sys:part_of
set.add name="ontology.historiography" id="historiography.period"

def "historiography.power" "Legitimacy, authority, sovereignty, and political uses of history."
ln historiography.power ont.historiography sys:part_of
