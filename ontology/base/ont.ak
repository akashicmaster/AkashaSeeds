def "ont.geo" "Physical geography: coordinates, places, features, observations, events, layers, and transitions. Managed by GeoConcept."
ln ont.geo ont.earth sys:part_of
set.add name="ontology.earth" id="ont.geo"

def "ont.geo_ref" "Geographic reference data: world countries (ISO3), US cities, US airports indexed by standard identifiers. Source: plotly/datasets (MIT)."
ln ont.geo_ref ont.earth sys:part_of
set.add name="ontology.earth" id="ont.geo_ref"

