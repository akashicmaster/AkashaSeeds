# Akasha ontology — namespace: ont
# atoms: 61

def "ont.advertising" "Root hub for advertising strategy, creative development, copywriting, media, and performance measurement."
set.add name="ontology.advertising" id="ont.advertising"

def "ont.ai" "Root hub: artificial intelligence, machine learning, LLMs, tooling, platforms."
set.add name="ontology.ai" id="ont.ai"

def "ont.automation" "Root hub for automation technologies including physical automation, control, robotics, information systems, intelligent automation, orchestration, and cybernetic integration."
set.add name="ontology.automation" id="ont.automation"

def "ont.biological_cybernetics" "Root hub for biological cybernetics including neural control, motor control, sensory systems, physiological regulation, homeostasis, adaptation, and brain–machine interfaces."
set.add name="ontology.biological_cybernetics" id="ont.biological_cybernetics"

def "ont.budgeting" "Root hub for budgeting, resource allocation, cost estimation, and financial planning across project lifecycles."
set.add name="ontology.budgeting" id="ont.budgeting"

def "ont.business" "Root hub: business concepts."
set.add name="ontology.business" id="ont.business"

def "ont.chemistry_reactions" "Root hub for chemical reactions and equilibrium."
set.add name="ontology.chemistry_reactions" id="ont.chemistry_reactions"

def "ont.cloud_networking" "Root hub for cloud networking, SDN, service mesh, cloud security, connectivity, distributed networking, and edge systems."
set.add name="ontology.cloud_networking" id="ont.cloud_networking"

def "ont.cognition" "Root hub for cognition, psychology, perception, attention, and mental processes."
set.add name="ontology.cognition" id="ont.cognition"

def "ont.community_gaming" "Community and gaming vocabulary: shared terms used in online games, forums, streaming culture, and social-geek communities."
set.add name="ontology.community_gaming" id="ont.community_gaming"

def "ont.computation_paradigms" "Root hub for alternative computation paradigms including quantum, neuromorphic, biological, analog, photonic, physical, and non-von Neumann architectures."
set.add name="ontology.computation_paradigms" id="ont.computation_paradigms"

def "ont.control_engineering" "Root hub for control engineering including classical feedback, state-space, optimal, robust, nonlinear, and digital control, as well as system identification and stability analysis."
set.add name="ontology.control_engineering" id="ont.control_engineering"

def "ont.country" "Political geography: states, polities, sovereignty, territories, populations, economies, laws, and disputes. Managed by CountryConcept."
ln ont.country ont.earth sys:part_of
set.add name="ontology.earth" id="ont.country"

def "ont.cryptography" "Root hub for cryptography including primitives, key management, protocols, PKI, data encryption, post-quantum cryptography, and security analysis."
set.add name="ontology.cryptography" id="ont.cryptography"

def "ont.culinary_science" "Root hub for culinary science and molecular reactions."
set.add name="ontology.culinary_science" id="ont.culinary_science"

def "ont.cybernetics" "Root hub for cybernetics including control, communication, self-organization, adaptation, biological, social, and machine cybernetic systems."
set.add name="ontology.cybernetics" id="ont.cybernetics"

def "ont.cybersecurity" "Root hub for cybersecurity including threats, defense, network security, application security, cloud security, incident response, and governance."
set.add name="ontology.cybersecurity" id="ont.cybersecurity"

def "ont.data_history" "Root hub: historical evolution of data storage, retrieval, and management."
set.add name="ontology.data" id="ont.data_history"

def "ont.data_migration" "Root hub for data migration strategies including assessment, cleansing, mapping, transformation, synchronization, execution, and validation."
set.add name="ontology.data_migration" id="ont.data_migration"

def "ont.earth" "Root hub: geoscientific and social-scientific knowledge of Earth — physical geography, polities, cartography, and spatial reference data."
