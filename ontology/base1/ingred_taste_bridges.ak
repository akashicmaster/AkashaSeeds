# Akasha ontology — ingredient → taste/colour perceptual links
# Generated by scripts/ingred_taste_bridge.py from the rec:* flavour scores.
# A score >= 0.6 links the ingredient to its perceptual atom
# (dna:taste:* / dna:color:*), which the sense/emotion bridges carry on to
# emo:* — so chains like  apple -> sweet -> joy  traverse from the ingredient.
# Links only, no new atoms. Re-run to extend as more ingredients get scored.

ln ingred:blend:curry_powder dna:taste:sweet thesaurus:related
ln ingred:condiment:coconut_milk dna:taste:sweet thesaurus:related
ln ingred:condiment:hoisin_sauce dna:taste:sweet thesaurus:related
ln ingred:condiment:honey dna:taste:sweet thesaurus:related
ln ingred:condiment:maple_syrup dna:taste:sweet thesaurus:related
ln ingred:condiment:sugar dna:taste:sweet thesaurus:related
ln ingred:condiment:teriyaki_sauce dna:taste:sweet thesaurus:related
ln ingred:condiment:wasabi dna:taste:sweet thesaurus:related
ln ingred:condiment:worcestershire_sauce dna:taste:sweet thesaurus:related
ln ingred:ferment:yogurt dna:taste:sweet thesaurus:related
ln ingred:fruit:apple dna:taste:sweet thesaurus:related
ln ingred:fruit:apricot dna:taste:sweet thesaurus:related
ln ingred:fruit:banana dna:taste:sweet thesaurus:related
ln ingred:fruit:blueberry dna:taste:sweet thesaurus:related
ln ingred:fruit:cherry dna:taste:sweet thesaurus:related
ln ingred:fruit:coconut dna:taste:sweet thesaurus:related
ln ingred:fruit:fig dna:taste:sweet thesaurus:related
ln ingred:fruit:grape dna:taste:sweet thesaurus:related
ln ingred:fruit:lemon dna:taste:sour thesaurus:related
ln ingred:fruit:mango dna:taste:sweet thesaurus:related
ln ingred:fruit:orange dna:taste:sweet thesaurus:related
ln ingred:fruit:papaya dna:taste:sweet thesaurus:related
ln ingred:fruit:peach dna:taste:sweet thesaurus:related
ln ingred:fruit:pear dna:taste:sweet thesaurus:related
ln ingred:fruit:pineapple dna:taste:sweet thesaurus:related
ln ingred:fruit:plum dna:taste:sweet thesaurus:related
ln ingred:fruit:pomegranate dna:taste:sweet thesaurus:related
ln ingred:fruit:strawberry dna:taste:sweet thesaurus:related
ln ingred:nut:chestnut dna:taste:sweet thesaurus:related
ln ingred:veg:shallot dna:taste:sweet thesaurus:related
ln ingred:veg:truffle dna:taste:sweet thesaurus:related

ln ingred:fruit:apple dna:color:red thesaurus:related
ln ingred:fruit:banana dna:color:yellow thesaurus:related
ln ingred:fruit:grape dna:color:green thesaurus:related
ln ingred:fruit:lemon dna:color:yellow thesaurus:related
ln ingred:fruit:orange dna:color:orange thesaurus:related
