set.add name="ontology.programming" id="prog:structural_pattern"

def "prog:structured_analysis" "Method for analyzing system requirements using data flow and process models."
ln prog:structured_analysis programming.engineering sys:is_a
ln prog:structured_analysis programming.oo @precedes
ln prog:structured_analysis prog:uml @precedes
set.add name="ontology.programming" id="prog:structured_analysis"

def "prog:structured_design" "Method for designing software using hierarchical decomposition and control structures."
ln prog:structured_design programming.engineering sys:is_a
ln prog:structured_design prog:structured_analysis @follows
ln prog:structured_design programming.oo @precedes
set.add name="ontology.programming" id="prog:structured_design"

def "prog:structured_programming" "Programming paradigm emphasizing sequence, selection, and iteration instead of arbitrary jumps."
ln prog:structured_programming programming.early sys:is_a
ln prog:structured_programming prog:goto @contrasts_with
ln prog:structured_programming programming.engineering @precedes
ln prog:structured_programming programming.early @evolves_from
set.add name="ontology.programming" id="prog:structured_programming"

def "prog:subroutine" "Reusable block of code invoked from multiple locations."
ln prog:subroutine programming.early sys:is_a
ln prog:subroutine programming.engineering @influences
ln prog:subroutine prog:top_down_design @influences
set.add name="ontology.programming" id="prog:subroutine"

def "prog:system_prompt_design" "Designing system-level instructions that shape an AI's role and constraints."
ln prog:system_prompt_design programming.ai sys:is_a
set.add name="ontology.programming" id="prog:system_prompt_design"

def "prog:system_testing" "Testing the complete integrated system to evaluate compliance with requirements."
ln prog:system_testing programming.engineering sys:is_a
set.add name="ontology.programming" id="prog:system_testing"

def "prog:tdd" "Test-Driven Development: writing tests before code."
ln prog:tdd prog:xp sys:is_a
ln prog:tdd programming.modern @influences
ln prog:tdd prog:hexagonal_architecture @influences
set.add name="ontology.programming" id="prog:tdd"

def "prog:timeout" "Limit on how long an operation may wait before failing."
ln prog:timeout prog:resilience sys:is_a
set.add name="ontology.programming" id="prog:timeout"

def "prog:tool_calling" "LLM-initiated invocation of external tools, APIs, or runtimes."
ln prog:tool_calling programming.ai sys:is_a
set.add name="ontology.programming" id="prog:tool_calling"

def "prog:top_down_design" "Design approach starting from high-level structure and refining into detailed components."
ln prog:top_down_design programming.engineering sys:is_a
set.add name="ontology.programming" id="prog:top_down_design"

def "prog:trace" "Record of a request's path through distributed components."
ln prog:trace prog:observability sys:is_a
set.add name="ontology.programming" id="prog:trace"

def "prog:ubiquitous_language" "Shared language between developers and domain experts."
ln prog:ubiquitous_language prog:ddd sys:is_a
set.add name="ontology.programming" id="prog:ubiquitous_language"

def "prog:uml" "Unified Modeling Language for visualizing and documenting OO systems."
ln prog:uml programming.oo sys:is_a
ln prog:uml programming.modern @precedes
set.add name="ontology.programming" id="prog:uml"

def "prog:user_story" "Short description of functionality from the user's perspective."
ln prog:user_story prog:scrum sys:is_a
set.add name="ontology.programming" id="prog:user_story"

def "prog:validation" "Process of ensuring software fulfills its intended purpose."
ln prog:validation programming.engineering sys:is_a
ln prog:validation prog:verification @contrasts_with
set.add name="ontology.programming" id="prog:validation"

def "prog:value_object" "Object defined by its attributes, immutable and identity-less."
ln prog:value_object prog:ddd sys:is_a
set.add name="ontology.programming" id="prog:value_object"

def "prog:vector_store_integration" "Connecting development workflows to vector databases for semantic search."
ln prog:vector_store_integration programming.ai sys:is_a
set.add name="ontology.programming" id="prog:vector_store_integration"

def "prog:verification" "Process of ensuring software meets its specifications."
ln prog:verification programming.engineering sys:is_a
set.add name="ontology.programming" id="prog:verification"

def "prog:waterfall_model" "Sequential development model with distinct phases: requirements → design → implementation → testing → maintenance."
ln prog:waterfall_model programming.engineering sys:is_a
set.add name="ontology.programming" id="prog:waterfall_model"

def "prog:web_api" "Interface allowing programmatic access to web-based services."
ln prog:web_api programming.web sys:is_a
ln prog:web_api prog:rest @often_implemented_as
set.add name="ontology.programming" id="prog:web_api"

def "prog:wip_limit" "Constraint on the number of tasks allowed in progress at once."
ln prog:wip_limit prog:kanban sys:is_a
set.add name="ontology.programming" id="prog:wip_limit"

def "prog:xp" "Agile methodology emphasizing engineering practices and code quality."
ln prog:xp programming.agile sys:is_a
ln prog:xp programming.oo @influences
set.add name="ontology.programming" id="prog:xp"
