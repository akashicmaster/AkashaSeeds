# Wine varietals — additional notable grapes (A-tier). Extends wine_varietals.ak.

def "wine:varietal:gamay" "Beaujolais grape — light, juicy, red-fruited."
ln wine:varietal:gamay wine:color:red sys:part_of
def "wine:varietal:semillon" "Waxy Bordeaux/Hunter grape; key in Sauternes sweet wine."
ln wine:varietal:semillon wine:color:white sys:part_of
def "wine:varietal:moscato" "Sweet, grapey, low-alcohol aromatic (Muscat)."
ln wine:varietal:moscato wine:color:white sys:part_of
